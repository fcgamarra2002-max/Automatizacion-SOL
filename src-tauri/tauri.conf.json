{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Automatizacion-SOL",
  "version": "0.1.2",
  "identifier": "com.sunat.automation.v1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Automatizacion-SOL",
        "width": 1000,
        "height": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "licenseFile": "LICENSE.txt",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": [
          "Spanish"
        ],
        "headerImage": "installer_banner.png",
        "sidebarImage": "installer_banner.png"
      }
    },
    "resources": [
      "data"
    ],
    "externalBin": [
      "binaries/sunat-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "fs": {},
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://raw.githubusercontent.com/fcgamarra2002-max/Automatizacion-SOL/master/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IHJzaWduIHB1YmxpYyBrZXkKUlNSVFkwSXlyM2xhZjVSUzlkaU1FbTRrRk9qR29oYmJkNkWUhPaGpwak85V0dJbldmMDgK"
    }
  }
}