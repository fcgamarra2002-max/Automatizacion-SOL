{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos para la ventana principal — sidecar Python para SUNAT",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/sunat-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/sunat-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "fs:default",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-resource-read",
    "fs:allow-app-read",
    "core:path:default",
    {
      "identifier": "fs:allow-applocaldata-read",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-applocaldata-write",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-resource-read",
      "allow": [
        {
          "path": "$RESOURCE/**"
        }
      ]
    }
  ]
}